#!/usr/bin/env bash
# apigee-cli — Manage Apigee proxy and shared flow bundles
# See README.md for full documentation, configuration, and installation.

set -euo pipefail

# ── Load user config (~/.apigee-cli, fallback to ~/.apigee-push) ─────────────
if [[ -f "${HOME}/.apigee-cli" ]]; then
  APIGEE_CLI_CONFIG="${HOME}/.apigee-cli"
elif [[ -f "${HOME}/.apigee-push" ]]; then
  APIGEE_CLI_CONFIG="${HOME}/.apigee-push"
else
  echo "ERROR: config file not found: ${HOME}/.apigee-cli"
  echo "       Create it with your org names and SA key paths."
  echo "       Run: apigee-cli --help for an example."
  exit 1
fi
# shellcheck source=/dev/null
source "$APIGEE_CLI_CONFIG"

# Validate required config variables are set
config_errors=0
for var in DEV_ORG DEV_SA_KEY TEST_ORG TEST_SA_KEY SAND_ORG SAND_SA_KEY STAGE_ORG STAGE_SA_KEY PROD_ORG PROD_SA_KEY; do
  if [[ -z "${!var:-}" ]]; then
    echo "ERROR: $var is not set in $APIGEE_CLI_CONFIG"
    config_errors=$((config_errors + 1))
  fi
done
[[ $config_errors -gt 0 ]] && exit 1

# ── Defaults ─────────────────────────────────────────────────────────────────
CWD="$(pwd)"
UPLOAD=true
DEPLOY=true
DOWNLOAD=false
DEPLOYED=false
CHECK=false
LIST=false
LIST_FILTER="all"
REVISION=""
ALL=false
VERBOSE=false
YES=false
ORG=""
TOKEN=""
ENV=""
SA_KEY_FILE=""
TARGETS=()

# ── Arg parsing ───────────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case "$1" in
    -u|--upload)   UPLOAD=true; shift ;;
    -d|--deploy)   DEPLOY=true; shift ;;
    -D|--download) DOWNLOAD=true; UPLOAD=false; DEPLOY=false; shift ;;
    -L|--list) LIST=true; UPLOAD=false; DEPLOY=false; DOWNLOAD=false; CHECK=false; shift
      # Optional filter: proxies, sharedflows, or all (default)
      if [[ $# -gt 0 && "$1" =~ ^(proxies|sharedflows|all)$ ]]; then
        LIST_FILTER="$1"; shift
      fi ;;
    -C|--check-version) CHECK=true; UPLOAD=false; DEPLOY=false; DOWNLOAD=false; shift ;;
    --deployed)    DEPLOYED=true; shift ;;
    -r|--revision) REVISION="$2"; shift 2 ;;
    -e|--env)      ENV="$2"; shift 2 ;;
    -o|--org)      ORG="$2"; shift 2 ;;
    -k|--sa-key)   SA_KEY_FILE="$2"; shift 2 ;;
    -t|--token)    TOKEN="$2"; shift 2 ;;
-a|--all)      ALL=true; shift ;;
    -v|--verbose)  VERBOSE=true; shift ;;
    -y|--yes)      YES=true; shift ;;
    --help|-h)
      cat <<'HELP'
apigee-cli — Manage Apigee proxy and shared flow bundles

Usage: apigee-cli [OPTIONS] [FOLDER_NAME ...]

Options:
  -u, --upload        Upload bundles to Apigee after zipping
  -d, --deploy        Deploy uploaded revision after upload (requires --env)
  -D, --download      Download revision from Apigee into local folder
      --deployed      Use with -D to get the currently deployed revision
  -r, --revision N    Use with -D to download a specific revision
  -L, --list          List all proxies/shared flows in an environment
  -C, --check-version Compare local files against Apigee revisions
  -e, --env <env>     Target environment: dev, test, sand, stage, prod
  -o, --org <org>     Override org from config
  -k, --sa-key <f>    Override SA key file from config
  -t, --token <tok>   Bearer token (overrides all auth)
  -a, --all           Process all bundles in current directory
  -v, --verbose       Print full API responses
  -y, --yes           Skip confirmation prompts
  -h, --help          Show this help

Examples:
  apigee-cli -e dev -d ais-openai-direct-v2     # deploy one bundle to dev
  apigee-cli -e prod -d -a                      # deploy all to prod
  apigee-cli -e dev -C -a                       # check all bundles vs dev
  apigee-cli -e dev -L                          # list all in dev
  apigee-cli -e dev -L proxies                  # list only proxies
  apigee-cli -e dev -D --deployed my-proxy      # download deployed rev

See README.md for configuration and installation instructions.
HELP
      exit 0
      ;;
    --*) echo "Unknown option: $1"; exit 1 ;;
    *)   TARGETS+=("$1"); shift ;;
  esac
done

# ── Resolve SA key from --env (--sa-key overrides) ───────────────────────────
ENV_PREFIX=""
if [[ -n "$ENV" ]]; then
  case "$ENV" in
    dev)   ENV_PREFIX="DEV" ;;
    test)  ENV_PREFIX="TEST" ;;
    sand)  ENV_PREFIX="SAND" ;;
    stage) ENV_PREFIX="STAGE" ;;
    prod)  ENV_PREFIX="PROD" ;;
    *) echo "ERROR: Unknown --env '$ENV'. Use: dev, test, sand, stage, or prod"; exit 1 ;;
  esac
  org_var="${ENV_PREFIX}_ORG"
  key_var="${ENV_PREFIX}_SA_KEY"
  [[ -z "$ORG" ]]        && ORG="${!org_var}"
  [[ -z "$SA_KEY_FILE" ]] && SA_KEY_FILE="${!key_var}"
fi

if [[ -n "$SA_KEY_FILE" && ! -f "$SA_KEY_FILE" ]]; then
  echo "ERROR: SA key file not found: $SA_KEY_FILE"
  if [[ ! -f "$APIGEE_CLI_CONFIG" ]]; then
    echo "       No config file found at $APIGEE_CLI_CONFIG"
    echo "       Create it to set custom SA key paths. Run: apigee-push --help"
  else
    echo "       Check ${ENV_PREFIX}_SA_KEY in $APIGEE_CLI_CONFIG"
  fi
  exit 1
fi

if $UPLOAD && [[ -n "$ENV" && -z "$ORG" ]]; then
  echo "ERROR: no org configured for env '$ENV'"
  if [[ ! -f "$APIGEE_CLI_CONFIG" ]]; then
    echo "       Create $APIGEE_CLI_CONFIG or use -o/--org to specify the org"
  else
    echo "       Check ${ENV_PREFIX}_ORG in $APIGEE_CLI_CONFIG"
  fi
  exit 1
fi

# ── Detect bundle type and canonical name from XML ────────────────────────────
detect_bundle_type() {
  local src="$1"
  if [[ -d "$src/proxies" ]]; then
    echo "apiproxy"
  elif [[ -d "$src/sharedflows" ]]; then
    echo "sharedflowbundle"
  else
    echo ""
  fi
}

detect_bundle_name() {
  local src="$1"
  # Find the root descriptor XML (APIProxy or SharedFlowBundle element) and extract name attribute
  grep -rh 'name="' "$src"/*.xml 2>/dev/null \
    | grep -E '<(APIProxy|SharedFlowBundle)[^>]+name=' \
    | grep -o 'name="[^"]*"' \
    | head -1 \
    | cut -d'"' -f2
}

# ── List mode (runs early — no bundles needed) ───────────────────────────────
if $LIST; then
  if [[ -z "$ENV" ]]; then
    echo "ERROR: --env is required for --list"
    exit 1
  fi
  if [[ -z "$ORG" ]]; then
    echo "ERROR: no org configured for env '$ENV'"
    exit 1
  fi

  # Resolve token
  if [[ -z "$TOKEN" ]]; then
    if [[ -n "$SA_KEY_FILE" ]]; then
      cfg="apigee-push-$$"
      gcloud config configurations create "$cfg" --no-activate > /dev/null 2>&1
      gcloud auth activate-service-account --key-file="$SA_KEY_FILE" \
        --configuration="$cfg" > /dev/null 2>&1
      TOKEN=$(gcloud auth print-access-token --configuration="$cfg" 2>/dev/null)
      gcloud config configurations delete "$cfg" --quiet > /dev/null 2>&1
      if [[ -z "$TOKEN" ]]; then
        echo "ERROR: failed to obtain access token from $SA_KEY_FILE"
        exit 1
      fi
    else
      TOKEN=$(gcloud auth print-access-token 2>/dev/null)
      if [[ -z "$TOKEN" ]]; then
        echo "ERROR: failed to obtain access token via gcloud"
        exit 1
      fi
    fi
  fi

  # Fetch proxy deployments in bulk (the env deployments endpoint only returns proxies)
  echo "Fetching deployments for env '$ENV'..."
  _deploy_resp=$(curl -s "https://apigee.googleapis.com/v1/organizations/${ORG}/environments/${ENV}/deployments" \
    -H "Authorization: Bearer ${TOKEN}") || true
  if $VERBOSE; then echo "$_deploy_resp" | jq . 2>/dev/null || true; fi

  # Build JSON object mapping proxy name → deployed revision
  _proxy_deploy_map=$(echo "$_deploy_resp" | jq -r '
    [.deployments[]? | select(.apiProxy) | {(.apiProxy): .revision}] | add // {}
  ' 2>/dev/null) || _proxy_deploy_map="{}"

  _list_deployed() {
    local kind="$1" label="$2" api_path="$3"
    local resp name deployed_rev latest_rev

    # Get list of all proxies/shared flows with their revision info (single API call)
    resp=$(curl -s "https://apigee.googleapis.com/v1/organizations/${ORG}/${api_path}?includeRevisions=true" \
      -H "Authorization: Bearer ${TOKEN}") || true

    if $VERBOSE; then echo "$resp" | jq . 2>/dev/null || true; fi

    # Extract names and latest revisions in one jq pass
    local entries
    entries=$(echo "$resp" | jq -r '
      (.proxies // .sharedFlows // [])[] |
      .name as $n |
      ((.revision // []) | map(tonumber) | max // "-" | tostring) as $latest |
      "\($n)\t\($latest)"
    ' 2>/dev/null) || true

    if [[ -z "$entries" ]]; then
      echo "  (none found)"
      return
    fi

    # For shared flows, the bulk env deployments endpoint doesn't include them,
    # so fetch each one's deployment in parallel
    local sf_deploy_map="{}"
    if [[ "$kind" == "sharedflow" ]]; then
      local sf_names tmp_dir
      sf_names=$(echo "$entries" | cut -f1)
      tmp_dir=$(mktemp -d)

      # Launch parallel curl calls for each shared flow's deployment status
      while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        curl -s "https://apigee.googleapis.com/v1/organizations/${ORG}/environments/${ENV}/sharedflows/${name}/deployments" \
          -H "Authorization: Bearer ${TOKEN}" \
          -o "${tmp_dir}/${name}.json" &
      done <<< "$sf_names"
      wait

      # Build the deployment map from parallel results
      sf_deploy_map="{"
      local first=true
      for f in "$tmp_dir"/*.json; do
        [[ ! -f "$f" ]] && continue
        name=$(basename "$f" .json)
        deployed_rev=$(jq -r '.deployments[0].revision // empty' "$f" 2>/dev/null) || true
        if [[ -n "$deployed_rev" ]]; then
          $first || sf_deploy_map+=","
          sf_deploy_map+="\"${name}\":\"${deployed_rev}\""
          first=false
        fi
      done
      sf_deploy_map+="}"
      rm -rf "$tmp_dir"
    fi

    printf "  %-50s  %-10s  %-10s\n" "NAME" "DEPLOYED" "LATEST"
    printf "  %-50s  %-10s  %-10s\n" "----" "--------" "------"

    while IFS=$'\t' read -r name latest_rev; do
      [[ -z "$name" ]] && continue
      if [[ "$kind" == "proxy" ]]; then
        deployed_rev=$(echo "$_proxy_deploy_map" | jq -r --arg n "$name" '.[$n] // "-"' 2>/dev/null) || deployed_rev="-"
      else
        deployed_rev=$(echo "$sf_deploy_map" | jq -r --arg n "$name" '.[$n] // "-"' 2>/dev/null) || deployed_rev="-"
      fi
      printf "  %-50s  %-10s  %-10s\n" "$name" "$deployed_rev" "$latest_rev"
    done <<< "$entries"
  }

  if [[ "$LIST_FILTER" == "all" || "$LIST_FILTER" == "proxies" ]]; then
    echo ""
    echo "API Proxies in org '$ORG' (env: $ENV):"
    _list_deployed "proxy" "Proxies" "apis"
  fi

  if [[ "$LIST_FILTER" == "all" || "$LIST_FILTER" == "sharedflows" ]]; then
    echo ""
    echo "Shared Flows in org '$ORG' (env: $ENV):"
    _list_deployed "sharedflow" "Shared Flows" "sharedflows"
  fi

  echo ""
  echo "Done."
  exit 0
fi

# ── Require a bundle name or --all ────────────────────────────────────────────
if $ALL; then
  # Auto-discover: any subdirectory with proxies/ or sharedflows/
  for dir in "$CWD"/*/; do
    name="$(basename "$dir")"
    [[ -n "$(detect_bundle_type "$dir")" ]] && TARGETS+=("$name")
  done
  if [[ ${#TARGETS[@]} -eq 0 ]]; then
    echo "ERROR: no bundles found under $CWD"
    exit 1
  fi
elif [[ ${#TARGETS[@]} -eq 0 ]]; then
  echo "ERROR: specify a bundle name or use --all (-a)"
  exit 1
fi

# ── Validate upload requirements ─────────────────────────────────────────────
if $UPLOAD && [[ -z "$ORG" ]]; then
  echo "ERROR: --org is required when using --upload"
  exit 1
fi

if $DEPLOY && [[ -z "$ENV" ]]; then
  echo "ERROR: --env is required when using --deploy"
  exit 1
fi

# ── Confirm before acting ─────────────────────────────────────────────────────
echo ""
echo "The following bundles were found:"
for BUNDLE in "${TARGETS[@]}"; do
  SRC="$CWD/$BUNDLE"
  if [[ -d "$SRC" ]]; then
    TYPE="$(detect_bundle_type "$SRC")"
    NAME="$(detect_bundle_name "$SRC" 2>/dev/null || echo "$BUNDLE")"
    [[ -z "$NAME" ]] && NAME="$BUNDLE"
    echo "  • $NAME ($TYPE) — $SRC"
  else
    echo "  • $BUNDLE — folder not found"
  fi
done
echo ""
if $CHECK; then
  echo "Action: check local vs latest + deployed revisions in env '$ENV' (org: $ORG)"
elif $DOWNLOAD && [[ -n "$REVISION" ]]; then
  echo "Action: download revision $REVISION from org '$ORG' to $CWD"
elif $DOWNLOAD && $DEPLOYED; then
  echo "Action: download deployed revision from env '$ENV' (org: $ORG) to $CWD"
elif $DOWNLOAD; then
  echo "Action: download latest revision from org '$ORG' to $CWD"
elif $UPLOAD && $DEPLOY; then
  echo "Action: upload + deploy to env '$ENV' (org: $ORG)"
elif $UPLOAD; then
  echo "Action: upload to org '$ORG'"
else
  echo "Action: zip only (no upload)"
fi
echo ""
if $YES; then
  echo "Proceeding (--yes)."
else
  read -r -p "Proceed? [y/N] " CONFIRM
  case "$CONFIRM" in
    y|Y) ;;
    *) echo "Aborted."; exit 0 ;;
  esac
fi
echo ""

WORK_DIR="$(mktemp -d)"
trap 'rm -rf "$WORK_DIR"' EXIT

# ── Resolve token once ────────────────────────────────────────────────────────
if ($UPLOAD || $DOWNLOAD || $CHECK) && [[ -z "$TOKEN" ]]; then
  if [[ -n "$SA_KEY_FILE" ]]; then
    echo "Authenticating with $SA_KEY_FILE ..."
    cfg="apigee-push-$$"
    gcloud config configurations create "$cfg" --no-activate > /dev/null 2>&1
    gcloud auth activate-service-account --key-file="$SA_KEY_FILE" \
      --configuration="$cfg" > /dev/null 2>&1
    TOKEN=$(gcloud auth print-access-token --configuration="$cfg" 2>/dev/null)
    gcloud config configurations delete "$cfg" --quiet > /dev/null 2>&1
    if [[ -z "$TOKEN" ]]; then
      echo "ERROR: failed to obtain access token from $SA_KEY_FILE"
      exit 1
    fi
    echo "  ✓ token obtained"
  else
    TOKEN=$(gcloud auth print-access-token 2>/dev/null)
    if [[ -z "$TOKEN" ]]; then
      echo "ERROR: failed to obtain access token via gcloud"
      exit 1
    fi
  fi
fi

# ── Helpers ───────────────────────────────────────────────────────────────────
LAST_REVISION=""

upload_proxy() {
  local name="$1" zip="$2" resp rev
  LAST_REVISION=""
  echo "  → Uploading proxy '$name' to org '$ORG'..."
  resp=$(curl -s -X POST \
    "https://apigee.googleapis.com/v1/organizations/${ORG}/apis?action=import&name=${name}" \
    -H "Authorization: Bearer ${TOKEN}" \
    -H "Content-Type: multipart/form-data" \
    -F "file=@${zip}") || true
  rev=$(echo "$resp" | jq -r '.revision // empty' 2>/dev/null) || true
  if [[ -n "$rev" ]]; then
    echo "  ✓ uploaded rev $rev"
    LAST_REVISION="$rev"
  else
    echo "  ERROR: upload failed — $(echo "$resp" | jq -r '.error.message // .error // "unknown error"' 2>/dev/null)"
  fi
  $VERBOSE && echo "$resp" | jq . 2>/dev/null || true
}

upload_sharedflow() {
  local name="$1" zip="$2" resp rev
  LAST_REVISION=""
  echo "  → Uploading shared flow '$name' to org '$ORG'..."
  resp=$(curl -s -X POST \
    "https://apigee.googleapis.com/v1/organizations/${ORG}/sharedflows?action=import&name=${name}" \
    -H "Authorization: Bearer ${TOKEN}" \
    -H "Content-Type: multipart/form-data" \
    -F "file=@${zip}") || true
  rev=$(echo "$resp" | jq -r '.revision // empty' 2>/dev/null) || true
  if [[ -n "$rev" ]]; then
    echo "  ✓ uploaded rev $rev"
    LAST_REVISION="$rev"
  else
    echo "  ERROR: upload failed — $(echo "$resp" | jq -r '.error.message // .error // "unknown error"' 2>/dev/null)"
  fi
  $VERBOSE && echo "$resp" | jq . 2>/dev/null || true
}

deploy_proxy() {
  local name="$1" rev="$2" resp
  echo "  → Deploying proxy '$name' rev $rev to env '$ENV'..."
  resp=$(curl -s -X POST \
    "https://apigee.googleapis.com/v1/organizations/${ORG}/environments/${ENV}/apis/${name}/revisions/${rev}/deployments?override=true" \
    -H "Authorization: Bearer ${TOKEN}" \
    -H "Content-Length: 0") || true
  if echo "$resp" | jq -e '.error' > /dev/null 2>&1; then
    echo "  ERROR: $(echo "$resp" | jq -r '.error.message // .error')"
  else
    echo "  ✓ deployed rev $(echo "$resp" | jq -r '.revision // "?"') to $ENV"
  fi
  $VERBOSE && echo "$resp" | jq . 2>/dev/null || true
}

deploy_sharedflow() {
  local name="$1" rev="$2" resp
  echo "  → Deploying shared flow '$name' rev $rev to env '$ENV'..."
  resp=$(curl -s -X POST \
    "https://apigee.googleapis.com/v1/organizations/${ORG}/environments/${ENV}/sharedflows/${name}/revisions/${rev}/deployments?override=true" \
    -H "Authorization: Bearer ${TOKEN}" \
    -H "Content-Length: 0") || true
  if echo "$resp" | jq -e '.error' > /dev/null 2>&1; then
    echo "  ERROR: $(echo "$resp" | jq -r '.error.message // .error')"
  else
    echo "  ✓ deployed rev $(echo "$resp" | jq -r '.revision // "?"') to $ENV"
  fi
  $VERBOSE && echo "$resp" | jq . 2>/dev/null || true
}

DETECTED_TYPE=""
DETECTED_REVISION=""

detect_remote_type() {
  local name="$1" resp
  DETECTED_TYPE=""
  DETECTED_REVISION=""
  resp=$(curl -s "https://apigee.googleapis.com/v1/organizations/${ORG}/apis/${name}/revisions" \
    -H "Authorization: Bearer ${TOKEN}") || true
  if echo "$resp" | jq -e 'type == "array"' > /dev/null 2>&1; then
    DETECTED_TYPE="apiproxy"
    DETECTED_REVISION=$(echo "$resp" | jq -r '[.[] | tonumber] | max | tostring' 2>/dev/null) || true
    return
  fi
  resp=$(curl -s "https://apigee.googleapis.com/v1/organizations/${ORG}/sharedflows/${name}/revisions" \
    -H "Authorization: Bearer ${TOKEN}") || true
  if echo "$resp" | jq -e 'type == "array"' > /dev/null 2>&1; then
    DETECTED_TYPE="sharedflowbundle"
    DETECTED_REVISION=$(echo "$resp" | jq -r '[.[] | tonumber] | max | tostring' 2>/dev/null) || true
    return
  fi
}

get_revision() {
  local type="$1" name="$2" resp rev
  if [[ -n "$REVISION" ]]; then
    echo "$REVISION"
    return
  fi
  if $DEPLOYED; then
    if [[ -z "$ENV" ]]; then
      echo "  ERROR: --env is required with --deployed"
      echo ""; return
    fi
    if [[ "$type" == "apiproxy" ]]; then
      resp=$(curl -s "https://apigee.googleapis.com/v1/organizations/${ORG}/environments/${ENV}/apis/${name}/deployments" \
        -H "Authorization: Bearer ${TOKEN}") || true
    else
      resp=$(curl -s "https://apigee.googleapis.com/v1/organizations/${ORG}/environments/${ENV}/sharedflows/${name}/deployments" \
        -H "Authorization: Bearer ${TOKEN}") || true
    fi
    rev=$(echo "$resp" | jq -r '.deployments[0].revision // empty' 2>/dev/null) || true
  else
    if [[ "$type" == "apiproxy" ]]; then
      resp=$(curl -s "https://apigee.googleapis.com/v1/organizations/${ORG}/apis/${name}/revisions" \
        -H "Authorization: Bearer ${TOKEN}") || true
    else
      resp=$(curl -s "https://apigee.googleapis.com/v1/organizations/${ORG}/sharedflows/${name}/revisions" \
        -H "Authorization: Bearer ${TOKEN}") || true
    fi
    rev=$(echo "$resp" | jq -r '[.[] | tonumber] | max | tostring' 2>/dev/null) || true
  fi
  if [[ -z "$rev" ]]; then
    echo "  ERROR: could not get revision — $(echo "$resp" | jq -r '.error.message // .error // "unknown error"' 2>/dev/null)"
  fi
  echo "$rev"
}

download_bundle() {
  local type="$1" name="$2" rev="$3"
  local zip="$WORK_DIR/${name}-rev${rev}.zip"
  local extract_dir="$WORK_DIR/${name}-extracted"
  local dest="$CWD/${name}"

  echo "  → Downloading $name rev $rev..."
  if [[ "$type" == "apiproxy" ]]; then
    curl -s -o "$zip" \
      "https://apigee.googleapis.com/v1/organizations/${ORG}/apis/${name}/revisions/${rev}?format=bundle" \
      -H "Authorization: Bearer ${TOKEN}" || true
  else
    curl -s -o "$zip" \
      "https://apigee.googleapis.com/v1/organizations/${ORG}/sharedflows/${name}/revisions/${rev}?format=bundle" \
      -H "Authorization: Bearer ${TOKEN}" || true
  fi

  if [[ ! -f "$zip" || ! -s "$zip" ]]; then
    echo "  ERROR: download failed or empty response"
    return
  fi

  mkdir -p "$extract_dir"
  unzip -q "$zip" -d "$extract_dir"

  # Apigee zips contain apiproxy/ or sharedflowbundle/ — move contents to dest folder
  local inner_dir="$extract_dir/$type"
  if [[ ! -d "$inner_dir" ]]; then
    echo "  ERROR: expected '$type/' folder inside downloaded zip"
    return
  fi

  if [[ -d "$dest" ]]; then
    # Preserve .git and any non-Apigee files (README.md etc) that Apigee doesn't know about
    find "$inner_dir" -mindepth 1 -maxdepth 1 | while read -r item; do
      rm -rf "$dest/$(basename "$item")"
      mv "$item" "$dest/"
    done
  else
    mv "$inner_dir" "$dest"
  fi
  echo "  ✓ extracted to $dest"
}

check_bundle() {
  local type="$1" name="$2" local_src="$3"
  local resp latest_rev deployed_rev

  # Get latest revision (highest number)
  if [[ "$type" == "apiproxy" ]]; then
    resp=$(curl -s "https://apigee.googleapis.com/v1/organizations/${ORG}/apis/${name}/revisions" \
      -H "Authorization: Bearer ${TOKEN}") || true
  else
    resp=$(curl -s "https://apigee.googleapis.com/v1/organizations/${ORG}/sharedflows/${name}/revisions" \
      -H "Authorization: Bearer ${TOKEN}") || true
  fi
  latest_rev=$(echo "$resp" | jq -r '[.[] | tonumber] | max | tostring' 2>/dev/null) || true

  # Get deployed revision for --env
  deployed_rev=""
  if [[ -n "$ENV" ]]; then
    if [[ "$type" == "apiproxy" ]]; then
      resp=$(curl -s "https://apigee.googleapis.com/v1/organizations/${ORG}/environments/${ENV}/apis/${name}/deployments" \
        -H "Authorization: Bearer ${TOKEN}") || true
    else
      resp=$(curl -s "https://apigee.googleapis.com/v1/organizations/${ORG}/environments/${ENV}/sharedflows/${name}/deployments" \
        -H "Authorization: Bearer ${TOKEN}") || true
    fi
    deployed_rev=$(echo "$resp" | jq -r '.deployments[0].revision // empty' 2>/dev/null) || true
  fi

  echo "  Latest revision : ${latest_rev:-unknown}"
  echo "  Deployed ($ENV)  : ${deployed_rev:-not deployed}"

  # Downloads a revision to a temp dir and diffs against local source
  _diff_rev() {
    local rev="$1" label="$2"
    local zip="$WORK_DIR/${name}-rev${rev}-check.zip"
    local extract_dir="$WORK_DIR/${name}-rev${rev}-check"

    if [[ "$type" == "apiproxy" ]]; then
      curl -s -o "$zip" \
        "https://apigee.googleapis.com/v1/organizations/${ORG}/apis/${name}/revisions/${rev}?format=bundle" \
        -H "Authorization: Bearer ${TOKEN}" || true
    else
      curl -s -o "$zip" \
        "https://apigee.googleapis.com/v1/organizations/${ORG}/sharedflows/${name}/revisions/${rev}?format=bundle" \
        -H "Authorization: Bearer ${TOKEN}" || true
    fi

    if [[ ! -f "$zip" || ! -s "$zip" ]]; then
      echo "  ERROR: could not download rev $rev for comparison"
      return
    fi

    mkdir -p "$extract_dir"
    unzip -q "$zip" -d "$extract_dir"

    local inner_dir="$extract_dir/$type"
    if [[ ! -d "$inner_dir" ]]; then
      echo "  ERROR: expected '$type/' folder inside rev $rev zip"
      return
    fi

    # Build a clean local copy (strip .git, .md, and root descriptor XML — same as what
    # apigee-push uploads, minus the root XML whose revision attr is overwritten by Apigee)
    local local_clean="$WORK_DIR/${name}-local-clean"
    rm -rf "$local_clean"
    cp -r "$local_src" "$local_clean"
    find "$local_clean" -name ".git" -type d -exec rm -rf {} + 2>/dev/null || true
    find "$local_clean" -name "*.md" -type f -delete 2>/dev/null || true
    find "$local_clean" -maxdepth 1 -name "*.xml" -type f -delete 2>/dev/null || true
    find "$inner_dir" -maxdepth 1 -name "*.xml" -type f -delete 2>/dev/null || true

    local diff_out
    diff_out=$(diff -rq "$local_clean" "$inner_dir" 2>/dev/null) || true
    if [[ -z "$diff_out" ]]; then
      echo "  ✓ $label (rev $rev): in sync with local"
    else
      echo "  ✗ $label (rev $rev): differs from local"
      echo "$diff_out" | sed 's/^/      /'
    fi
  }

  if [[ -n "$latest_rev" ]]; then
    _diff_rev "$latest_rev" "Latest"
  fi

  if [[ -n "$deployed_rev" && "$deployed_rev" != "$latest_rev" ]]; then
    _diff_rev "$deployed_rev" "Deployed"
  elif [[ -n "$deployed_rev" && "$deployed_rev" == "$latest_rev" ]]; then
    echo "  (deployed rev matches latest — no separate diff needed)"
  fi
}

# ── Git branch check ─────────────────────────────────────────────────────────
check_git_branch() {
  local bundle_dir="$1"
  local expected_branch=""
  case "$ENV" in
    dev|test|sand) expected_branch="development" ;;
    stage)         expected_branch="stage" ;;
    prod)          expected_branch="main" ;;
  esac
  [[ -z "$expected_branch" ]] && return

  if ! git -C "$bundle_dir" rev-parse --is-inside-work-tree > /dev/null 2>&1; then
    return  # not a git repo, skip
  fi

  local current_branch
  current_branch=$(git -C "$bundle_dir" rev-parse --abbrev-ref HEAD 2>/dev/null) || return

  if [[ "$current_branch" != "$expected_branch" ]]; then
    echo "  ⚠  WARNING: '$bundle_dir' is on branch '$current_branch' (expected '$expected_branch' for env '$ENV')"
    if ! $YES; then
      read -r -p "  Continue anyway? [y/N] " BRANCH_CONFIRM
      case "$BRANCH_CONFIRM" in
        y|Y) ;;
        *) echo "  Aborted."; exit 0 ;;
      esac
    fi
  fi
}

# ── Pre-deploy check: warn if deployed revision differs from local ────────────
precheck_deployed() {
  local type="$1" name="$2" local_src="$3"
  local resp deployed_rev zip extract_dir inner_dir local_clean diff_out

  # Get currently deployed revision
  if [[ "$type" == "apiproxy" ]]; then
    resp=$(curl -s "https://apigee.googleapis.com/v1/organizations/${ORG}/environments/${ENV}/apis/${name}/deployments" \
      -H "Authorization: Bearer ${TOKEN}") || true
  else
    resp=$(curl -s "https://apigee.googleapis.com/v1/organizations/${ORG}/environments/${ENV}/sharedflows/${name}/deployments" \
      -H "Authorization: Bearer ${TOKEN}") || true
  fi
  deployed_rev=$(echo "$resp" | jq -r '.deployments[0].revision // empty' 2>/dev/null) || true

  if [[ -z "$deployed_rev" ]]; then
    return  # nothing deployed yet, no check needed
  fi

  # Download deployed revision to temp dir
  zip="$WORK_DIR/${name}-predeploy-rev${deployed_rev}.zip"
  extract_dir="$WORK_DIR/${name}-predeploy-rev${deployed_rev}"
  if [[ "$type" == "apiproxy" ]]; then
    curl -s -o "$zip" \
      "https://apigee.googleapis.com/v1/organizations/${ORG}/apis/${name}/revisions/${deployed_rev}?format=bundle" \
      -H "Authorization: Bearer ${TOKEN}" || true
  else
    curl -s -o "$zip" \
      "https://apigee.googleapis.com/v1/organizations/${ORG}/sharedflows/${name}/revisions/${deployed_rev}?format=bundle" \
      -H "Authorization: Bearer ${TOKEN}" || true
  fi

  if [[ ! -f "$zip" || ! -s "$zip" ]]; then
    return  # can't download, skip check
  fi

  mkdir -p "$extract_dir"
  unzip -q "$zip" -d "$extract_dir"
  inner_dir="$extract_dir/$type"
  [[ ! -d "$inner_dir" ]] && return

  # Clean local copy the same way check_bundle does
  local_clean="$WORK_DIR/${name}-predeploy-local"
  rm -rf "$local_clean"
  cp -r "$local_src" "$local_clean"
  find "$local_clean" -name ".git" -type d -exec rm -rf {} + 2>/dev/null || true
  find "$local_clean" -name "*.md" -type f -delete 2>/dev/null || true
  find "$local_clean" -maxdepth 1 -name "*.xml" -type f -delete 2>/dev/null || true
  find "$inner_dir" -maxdepth 1 -name "*.xml" -type f -delete 2>/dev/null || true

  diff_out=$(diff -rq "$local_clean" "$inner_dir" 2>/dev/null) || true
  if [[ -n "$diff_out" ]]; then
    echo "  ⚠  WARNING: deployed rev $deployed_rev in '$ENV' differs from local — someone may have updated it"
    echo "$diff_out" | sed 's/^/      /'
    if ! $YES; then
      read -r -p "  Deploy anyway? [y/N] " PRECHECK_CONFIRM
      case "$PRECHECK_CONFIRM" in
        y|Y) ;;
        *) echo "  Aborted."; exit 0 ;;
      esac
    fi
  fi
}

# ── Main loop ─────────────────────────────────────────────────────────────────
ERRORS=0
for BUNDLE in "${TARGETS[@]}"; do
  SRC="$CWD/$BUNDLE"

  if [[ ! -d "$SRC" ]]; then
    if $DOWNLOAD; then
      echo "Downloading: $BUNDLE (folder not found locally — detecting type from Apigee...)"
      detect_remote_type "$BUNDLE"
      if [[ -z "$DETECTED_TYPE" ]]; then
        echo "  SKIP: '$BUNDLE' not found in org '$ORG'"
        ((ERRORS++)) || true
        continue
      fi
      echo "  detected as $DETECTED_TYPE"
      if [[ -n "$REVISION" ]] || $DEPLOYED; then
        REV="$(get_revision "$DETECTED_TYPE" "$BUNDLE")"
      else
        REV="$DETECTED_REVISION"
      fi
      if [[ -n "$REV" ]]; then
        download_bundle "$DETECTED_TYPE" "$BUNDLE" "$REV"
      fi
      continue
    fi
    echo "SKIP: '$SRC' directory not found"
    ((ERRORS++)) || true
    continue
  fi

  INNER="$(detect_bundle_type "$SRC")"
  if [[ -z "$INNER" ]]; then
    echo "SKIP: '$BUNDLE' — no proxies/ or sharedflows/ directory found"
    ((ERRORS++)) || true
    continue
  fi

  BUNDLE_NAME="$(detect_bundle_name "$SRC")"
  if [[ -z "$BUNDLE_NAME" ]]; then
    echo "WARN: could not read name from XML for '$BUNDLE', falling back to folder name"
    BUNDLE_NAME="$BUNDLE"
  fi

  if $DOWNLOAD; then
    echo "Downloading: $BUNDLE_NAME ($INNER)"
    REV="$(get_revision "$INNER" "$BUNDLE_NAME")"
    if [[ -n "$REV" ]]; then
      download_bundle "$INNER" "$BUNDLE_NAME" "$REV"
    fi
    continue
  fi

  if $CHECK; then
    echo "Checking: $BUNDLE_NAME ($INNER)"
    check_bundle "$INNER" "$BUNDLE_NAME" "$SRC"
    echo ""
    continue
  fi

  if $UPLOAD; then
    check_git_branch "$SRC"
  fi

  if $DEPLOY; then
    precheck_deployed "$INNER" "$BUNDLE_NAME" "$SRC"
  fi

  ZIP="$WORK_DIR/${BUNDLE_NAME}.zip"
  STAGE_DIR="$WORK_DIR/${BUNDLE_NAME}-stage"

  echo "Bundling: $BUNDLE_NAME (internal folder: $INNER/)"

  mkdir -p "$STAGE_DIR"
  cp -r "$SRC" "$STAGE_DIR/$INNER"
  find "$STAGE_DIR" -name ".git" -type d -exec rm -rf {} + 2>/dev/null || true
  find "$STAGE_DIR" -name "*.md" -type f -delete 2>/dev/null || true
  (cd "$STAGE_DIR" && zip -qr "$ZIP" "$INNER")

  echo "  ✓ $(du -sh "$ZIP" | cut -f1)"

  if $UPLOAD; then
    if [[ "$INNER" == "apiproxy" ]]; then
      upload_proxy "$BUNDLE_NAME" "$ZIP"
    else
      upload_sharedflow "$BUNDLE_NAME" "$ZIP"
    fi

    if $DEPLOY; then
      if [[ -z "$LAST_REVISION" ]]; then
        echo "  SKIP deploy: upload did not return a revision"
      elif [[ "$INNER" == "apiproxy" ]]; then
        deploy_proxy "$BUNDLE_NAME" "$LAST_REVISION"
      else
        deploy_sharedflow "$BUNDLE_NAME" "$LAST_REVISION"
      fi
    fi
  fi

done

echo ""
if [[ $ERRORS -eq 0 ]]; then
  echo "Done."
else
  echo "Done with $ERRORS skipped."
fi
